    border-bottom-width: 2px;
    border-left-color: rgba(92, 213, 203, 0.92);
    border-right-color: rgba(82, 171, 205, 0.68);
    border-top-color: rgba(82, 171, 205, 0.68);
    border-bottom-color: rgba(82, 171, 205, 0.68);
    background-color: rgba(24, 58, 64, 0.92);
}

.dpi-graph-group.dpi-graph-search--context .dpi-graph-group__symbol {
    border-left-color: rgba(82, 171, 205, 0.52);
    border-right-color: rgba(82, 171, 205, 0.36);
    border-top-color: rgba(82, 171, 205, 0.36);
    border-bottom-color: rgba(82, 171, 205, 0.36);
}

.dpi-graph-group.dpi-graph-search--context {
    opacity: 0.78;
}

.dpi-graph-group.dpi-graph-search--dimmed {
    opacity: 0.44;
}

.dpi-graph-group.dpi-graph-search--dimmed.dpi-graph-group--hover-context {
    opacity: 0.72;
}

.dpi-graph-group--integration .dpi-graph-group__symbol {
    border-left-color: rgba(59, 209, 191, 0.54);
}

.dpi-graph-group--suite .dpi-graph-group__symbol {
    border-left-color: rgba(141, 123, 204, 0.52);
}

.dpi-graph-group--attention .dpi-graph-group__symbol {
    border-left-color: rgba(217, 157, 72, 0.86);
}

.dpi-graph-group--attention:hover .dpi-graph-group__symbol {
    border-left-color: rgba(255, 226, 184, 0.96);
}

.dpi-graph-group--focused.dpi-graph-group--attention .dpi-graph-group__symbol,
.dpi-graph-group--hover-context.dpi-graph-group--attention .dpi-graph-group__symbol,
.dpi-graph-group.dpi-graph-search--match.dpi-graph-group--attention .dpi-graph-group__symbol {
    border-left-color: rgba(255, 226, 184, 0.96);
}

.dpi-graph-group__icon {
    width: 28px;
    height: 28px;
    opacity: 0.86;
}

.dpi-graph-back-hint {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    min-width: 16px;
    max-width: 16px;
    min-height: 16px;
    max-height: 16px;
    padding-left: 0;
    padding-right: 0;
    padding-top: 0;
    padding-bottom: 0;
    -unity-text-align: middle-center;
    color: rgba(151, 224, 218, 0.72);
    font-size: 15px;
    -unity-font-style: bold;
    background-color: rgba(0, 0, 0, 0);
}

.dpi-graph-back-hint--category {
    margin-right: 4px;
}

.dpi-graph-group--has-back:hover .dpi-graph-group__back-hint {
    color: rgba(219, 252, 247, 0.94);
}

.dpi-graph-category-caption-row {
    flex-direction: row;
    align-items: center;
    justify-content: center;
    min-height: 16px;
}

.dpi-graph-group__title {
    margin-top: 0;
    color: rgba(234, 244, 247, 0.92);
    -unity-font-style: bold;
    font-size: 12px;
    white-space: normal;
    max-height: 32px;
    -unity-text-align: middle-center;
    flex-shrink: 1;
}

.dpi-graph-group__subtitle {
    margin-top: 2px;
    color: rgba(151, 184, 195, 0.78);
    font-size: 9px;
    white-space: normal;
    max-height: 24px;
    -unity-text-align: middle-center;
}

.dpi-graph-group__stats {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 5px;
}

.dpi-graph-group__stat {
    height: 15px;
    margin-right: 4px;
    margin-bottom: 3px;
    padding-left: 0;
    padding-right: 6px;
    background-color: rgba(0, 0, 0, 0);
    color: rgba(209, 222, 228, 0.84);
    font-size: 8px;
}

.dpi-graph-group__stat--installed {
    color: rgba(124, 214, 197, 0.88);
}

.dpi-graph-group__stat--available {
    color: rgba(190, 184, 242, 0.88);
}

.dpi-graph-group__stat--attention {
    color: rgba(255, 236, 184, 0.94);
}

.dpi-graph-group__stat--unknown {
    color: rgba(154, 177, 188, 0.82);
}

.dpi-graph-node--installed {
    border-bottom-color: rgba(59, 166, 154, 0.58);
    background-color: rgba(25, 43, 49, 0.84);
}

.dpi-graph-node--companion {
    border-left-color: rgba(90, 111, 160, 0.62);
}

.dpi-graph-node--suite {
    border-left-color: rgba(59, 166, 154, 0.66);
}

.dpi-graph-node--integration {
    border-left-color: rgba(66, 146, 184, 0.58);
}

.dpi-graph-node--missing {
    border-left-color: rgba(217, 157, 72, 0.72);
    border-right-color: rgba(217, 157, 72, 0.48);
    border-top-color: rgba(217, 157, 72, 0.48);
    border-bottom-color: rgba(217, 157, 72, 0.48);
}

.dpi-graph-node--status-update {
    border-bottom-width: 2px;
    border-bottom-color: rgba(224, 178, 72, 0.92);
    background-color: rgba(48, 41, 29, 0.86);
}

.dpi-graph-node--status-warning {
    border-bottom-width: 2px;
    border-bottom-color: rgba(226, 132, 60, 0.82);
    background-color: rgba(48, 37, 29, 0.84);
}

.dpi-graph-node--status-missing {
    border-bottom-width: 2px;
    border-bottom-color: rgba(229, 96, 76, 0.86);
    background-color: rgba(48, 31, 31, 0.84);
}

.dpi-graph-node--status-update:hover {
    border-bottom-color: rgba(240, 194, 88, 0.96);
    background-color: rgba(56, 47, 32, 0.90);
}

.dpi-graph-node--status-update.dpi-graph-node--selected {
    border-bottom-color: rgba(240, 194, 88, 1.00);
    background-color: rgba(54, 55, 38, 0.90);
}

.dpi-graph-node__header {
    flex-direction: row;
    min-height: 48px;
    max-height: 52px;
    flex-shrink: 0;
    align-items: center;
}

.dpi-graph-node__back-hint {
    margin-left: 0;
    margin-right: 6px;
}

.dpi-graph-node--has-back:hover .dpi-graph-node__back-hint {
    color: rgba(219, 252, 247, 0.96);
}

.dpi-graph-node__icon {
    width: 30px;
    height: 30px;
    min-width: 30px;
    margin-right: 8px;
    opacity: 0.92;
}

.dpi-graph-node__status-icon {
    width: 18px;
    min-width: 18px;
    height: 18px;
    margin-left: 7px;
    margin-right: 0;
    padding-left: 0;
    padding-right: 0;
    border-top-left-radius: 999px;
    border-top-right-radius: 999px;
    border-bottom-right-radius: 999px;
    border-bottom-left-radius: 999px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(111, 136, 163, 0.36);
    border-right-color: rgba(111, 136, 163, 0.36);
    border-top-color: rgba(111, 136, 163, 0.36);
    border-bottom-color: rgba(111, 136, 163, 0.36);
    -unity-text-align: middle-center;
    font-size: 10px;
    -unity-font-style: bold;
    color: rgba(228, 241, 244, 0.90);
    background-color: rgba(0, 0, 0, 0);
}

.dpi-graph-node__status-icon--installed {
    color: rgba(212, 247, 238, 0.96);
    border-left-color: rgba(69, 193, 175, 0.58);
    border-right-color: rgba(69, 193, 175, 0.58);
    border-top-color: rgba(69, 193, 175, 0.58);
    border-bottom-color: rgba(69, 193, 175, 0.58);
    background-color: rgba(35, 111, 104, 0.10);
}

.dpi-graph-node__status-icon--available {
    color: rgba(168, 181, 194, 0.92);
    border-left-color: rgba(122, 140, 158, 0.50);
    border-right-color: rgba(122, 140, 158, 0.50);
    border-top-color: rgba(122, 140, 158, 0.50);
    border-bottom-color: rgba(122, 140, 158, 0.50);
    background-color: rgba(29, 36, 47, 0.04);
}

.dpi-graph-node__status-icon--update {
    color: rgba(255, 240, 200, 0.98);
    border-left-color: rgba(220, 178, 75, 0.72);
    border-right-color: rgba(220, 178, 75, 0.72);
    border-top-color: rgba(220, 178, 75, 0.72);
    border-bottom-color: rgba(220, 178, 75, 0.72);
    background-color: rgba(129, 96, 35, 0.10);
}

.dpi-graph-node__status-icon--warning {
    color: rgba(255, 226, 194, 0.98);
    border-left-color: rgba(223, 135, 68, 0.68);
    border-right-color: rgba(223, 135, 68, 0.68);
    border-top-color: rgba(223, 135, 68, 0.68);
    border-bottom-color: rgba(223, 135, 68, 0.68);
    background-color: rgba(137, 75, 35, 0.10);
}

.dpi-graph-node__status-icon--missing {
    color: rgba(255, 224, 216, 0.98);
    border-left-color: rgba(225, 105, 91, 0.70);
    border-right-color: rgba(225, 105, 91, 0.70);
    border-top-color: rgba(225, 105, 91, 0.70);
    border-bottom-color: rgba(225, 105, 91, 0.70);
    background-color: rgba(137, 54, 45, 0.10);
}

.dpi-graph-node__status-icon--checking {
    color: rgba(187, 227, 241, 0.98);
    border-left-color: rgba(82, 171, 205, 0.66);
    border-right-color: rgba(82, 171, 205, 0.66);
    border-top-color: rgba(82, 171, 205, 0.66);
    border-bottom-color: rgba(82, 171, 205, 0.66);
    background-color: rgba(31, 89, 112, 0.12);
}

.dpi-graph-node__title-block {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 0;
}

.dpi-graph-node__title {
    color: var(--deucarian-text);
    -unity-font-style: bold;
    font-size: 12px;
    white-space: normal;
    max-height: 34px;
    flex-shrink: 0;
}

.dpi-graph-node__package-id {
    color: var(--deucarian-muted);
    font-size: 9px;
    white-space: nowrap;
    max-height: 13px;
    flex-shrink: 0;
}

.dpi-graph-node__category-path {
    margin-top: 3px;
    color: rgba(139, 184, 196, 0.76);
    font-size: 9px;
    white-space: nowrap;
    max-height: 15px;
    flex-shrink: 0;
}

.dpi-ecosystem-graph__content--low-zoom .dpi-graph-group__stats {
    display: none;
}

.dpi-ecosystem-graph__content--low-zoom .dpi-graph-group__title {
    font-size: 11px;
}

.dpi-ecosystem-graph__content--low-zoom .dpi-graph-group__subtitle {
    font-size: 8px;
}

.dpi-graph-node__badges {
    flex-direction: row;
    margin-top: 6px;
    margin-bottom: 5px;
    min-height: 18px;
    max-height: 20px;
    flex-shrink: 0;
}

.dpi-graph-node__badge {
    height: 18px;
    margin-right: 4px;
    font-size: 9px;
    max-width: 96px;
    padding-left: 0;
    padding-right: 8px;
    color: rgba(190, 207, 214, 0.86);
    background-color: rgba(0, 0, 0, 0);
}

.dpi-graph-node__badge--type {
    color: rgba(139, 174, 194, 0.82);
}

.dpi-graph-node__badge--installed {
    color: rgba(124, 214, 197, 0.90);
}

.dpi-graph-node__badge--available {
    color: rgba(166, 181, 194, 0.88);
}

.dpi-graph-node__badge--update {
    color: rgba(255, 236, 184, 0.96);
}

.dpi-graph-node__badge--checking {
    color: rgba(151, 206, 226, 0.88);
}

.dpi-graph-node__badge--warning {
    color: rgba(255, 215, 172, 0.92);
}

.dpi-graph-node__badge--missing {
    color: rgba(255, 198, 176, 0.92);
}

.dpi-graph-node__footer {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    min-height: 26px;
    max-height: 28px;
    flex-shrink: 0;
    margin-top: 2px;
}

.dpi-graph-node__channel {
    color: rgba(154, 194, 202, 0.76);
    font-size: 9px;
}

.dpi-graph-node__action {
    min-width: 76px;
    height: 23px;
    max-height: 23px;
    padding-left: 8px;
    padding-right: 8px;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
    border-bottom-right-radius: 5px;
    border-bottom-left-radius: 5px;
    background-color: rgba(35, 82, 87, 0.68);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(59, 166, 154, 0.48);
    border-right-color: rgba(59, 166, 154, 0.48);
    border-top-color: rgba(59, 166, 154, 0.48);
    border-bottom-color: rgba(59, 166, 154, 0.48);
    color: var(--deucarian-text);
    font-size: 10px;
}

.dpi-graph-node__action:hover {
    background-color: rgba(42, 108, 112, 0.76);
    border-left-color: rgba(59, 166, 154, 0.70);
    border-right-color: rgba(59, 166, 154, 0.70);
    border-top-color: rgba(59, 166, 154, 0.70);
    border-bottom-color: rgba(59, 166, 154, 0.70);
}

.dpi-graph-node__action:active {
    background-color: rgba(25, 74, 82, 0.88);
    border-left-color: rgba(59, 209, 191, 0.84);
    border-right-color: rgba(59, 209, 191, 0.84);
    border-top-color: rgba(59, 209, 191, 0.84);
    border-bottom-color: rgba(59, 209, 191, 0.84);
}

.dpi-graph-node--status-update .dpi-graph-node__action {
    background-color: rgba(112, 84, 31, 0.82);
    border-left-color: rgba(224, 178, 72, 0.60);
    border-right-color: rgba(224, 178, 72, 0.60);
    border-top-color: rgba(224, 178, 72, 0.60);
    border-bottom-color: rgba(224, 178, 72, 0.60);
    color: rgba(255, 241, 206, 0.98);
}

.dpi-graph-node--status-update .dpi-graph-node__action:hover {
    background-color: rgba(132, 100, 38, 0.90);
    border-left-color: rgba(240, 194, 88, 0.82);
    border-right-color: rgba(240, 194, 88, 0.82);
    border-top-color: rgba(240, 194, 88, 0.82);
    border-bottom-color: rgba(240, 194, 88, 0.82);
}

.dpi-graph-node--status-update .dpi-graph-node__action:active {
    background-color: rgba(96, 69, 25, 0.94);
    border-left-color: rgba(255, 213, 112, 0.94);
    border-right-color: rgba(255, 213, 112, 0.94);
    border-top-color: rgba(255, 213, 112, 0.94);
    border-bottom-color: rgba(255, 213, 112, 0.94);
}
