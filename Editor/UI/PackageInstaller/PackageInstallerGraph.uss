.dpi-fixed-wallpaper-layer,
.dpi-fixed-wallpaper-overlay {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}

.dpi-view-toolbar {
    margin-bottom: 8px;
    flex-wrap: wrap;
    align-items: center;
}

.dpi-view-toolbar__summary {
    margin-left: 8px;
    color: var(--deucarian-muted);
    font-size: 11px;
    min-width: 0;
    flex-shrink: 1;
}

.dpi-view-toolbar__action {
    height: 24px;
    min-width: 86px;
    margin-left: 4px;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
    border-bottom-right-radius: 5px;
    border-bottom-left-radius: 5px;
    background-color: rgba(32, 47, 56, 0.50);
    color: var(--deucarian-text);
}

.dpi-mode-container {
    flex-grow: 1;
    flex-shrink: 1;
    min-height: 0;
}

.dpi-mode-container--hidden {
    display: none;
}

.dpi-graph-mode {
    flex-grow: 1;
    flex-shrink: 1;
    flex-direction: column;
    min-height: 0;
}

.dpi-graph-content-row {
    flex-grow: 1;
    flex-shrink: 1;
    flex-basis: 0;
    flex-direction: row;
    align-items: stretch;
    min-height: 0;
    margin-bottom: 8px;
}

.dpi-graph-details {
    width: 410px;
    min-width: 360px;
    max-width: 440px;
    flex-grow: 0;
    flex-shrink: 0;
    align-self: stretch;
    min-height: 0;
    margin-left: 8px;
    overflow: hidden;
}

.dpi-operation-drawer {
    flex-shrink: 0;
    height: 0;
    min-height: 0;
    max-height: 0;
    margin-top: 0;
    overflow: hidden;
}

.dpi-operation-drawer--expanded {
    margin-bottom: 6px;
}

.dpi-operation-drawer--collapsed {
    margin-bottom: 0;
}

.dpi-operation-footer {
    flex-shrink: 0;
    height: 34px;
    min-height: 34px;
    max-height: 34px;
    margin-top: 0;
    overflow: hidden;
}

.dpi-responsive--compact .dpi-graph-details {
    width: 350px;
    min-width: 310px;
    max-width: 370px;
}

.dpi-responsive--compact .dpi-view-toolbar__action {
    min-width: 76px;
    padding-left: 6px;
    padding-right: 6px;
}

.dpi-responsive--narrow .dpi-view-toolbar {
    min-height: 58px;
    align-items: center;
}

.dpi-responsive--narrow .dpi-view-toolbar__summary {
    width: 100%;
    margin-left: 0;
    margin-top: 4px;
}

.dpi-responsive--narrow .dpi-graph-content-row {
    flex-direction: column;
    margin-bottom: 6px;
}

.dpi-responsive--narrow .dpi-graph-details {
    width: auto;
    min-width: 0;
    max-width: none;
    height: 190px;
    min-height: 150px;
    max-height: 220px;
    margin-left: 0;
    margin-top: 8px;
    align-self: stretch;
    flex-grow: 0;
    flex-shrink: 0;
}

.dpi-ecosystem-graph {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 420px;
    min-height: 0;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
    border-bottom-left-radius: 8px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(90, 111, 160, 0.34);
    border-right-color: rgba(90, 111, 160, 0.34);
    border-top-color: rgba(90, 111, 160, 0.34);
    border-bottom-color: rgba(90, 111, 160, 0.34);
    background-color: rgba(11, 18, 25, 0.62);
}

.dpi-responsive--narrow .dpi-ecosystem-graph {
    min-width: 0;
    min-height: 300px;
}

.dpi-ecosystem-graph__header {
    flex-shrink: 0;
    flex-direction: column;
    align-items: stretch;
    border-bottom-width: 1px;
    border-bottom-color: rgba(90, 111, 160, 0.22);
    background-color: rgba(20, 30, 38, 0.72);
}

.dpi-ecosystem-graph__filter-row {
    min-height: 36px;
    flex-direction: row;
    align-items: center;
    padding-left: 10px;
    padding-right: 8px;
    padding-top: 6px;
    padding-bottom: 4px;
}

.dpi-ecosystem-graph__breadcrumbs {
    min-height: 24px;
    flex-direction: row;
    align-items: center;
    padding-left: 10px;
    padding-right: 8px;
    padding-bottom: 3px;
}

.dpi-ecosystem-graph__breadcrumbs--root {
    opacity: 0.78;
}

.dpi-ecosystem-graph__breadcrumb {
    height: 20px;
    min-width: 0;
    padding-left: 8px;
    padding-right: 8px;
    border-top-left-radius: 3px;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
    border-bottom-left-radius: 3px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(90, 111, 160, 0.26);
    border-right-color: rgba(90, 111, 160, 0.26);
    border-top-color: rgba(90, 111, 160, 0.26);
    border-bottom-color: rgba(90, 111, 160, 0.26);
    background-color: rgba(20, 34, 43, 0.62);
    color: rgba(205, 224, 230, 0.86);
    font-size: 10px;
}

.dpi-ecosystem-graph__breadcrumb:hover {
    border-left-color: rgba(59, 166, 154, 0.48);
    border-right-color: rgba(59, 166, 154, 0.48);
    border-top-color: rgba(59, 166, 154, 0.48);
    border-bottom-color: rgba(59, 166, 154, 0.48);
    background-color: rgba(27, 52, 57, 0.68);
}

.dpi-ecosystem-graph__breadcrumb-current {
    height: 20px;
    padding-left: 8px;
    padding-right: 8px;
    color: rgba(230, 242, 245, 0.92);
    font-size: 10px;
    -unity-font-style: bold;
}

.dpi-ecosystem-graph__breadcrumb-separator {
    width: 12px;
    color: rgba(112, 143, 156, 0.70);
    -unity-text-align: middle-center;
    font-size: 10px;
}

.dpi-ecosystem-graph__search {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 130px;
    max-width: 360px;
    height: 24px;
    margin-right: 6px;
}

.dpi-ecosystem-graph__filter-toggle,
.dpi-ecosystem-graph__filter-clear {
    height: 22px;
    min-width: 96px;
    margin-left: 4px;
    padding-left: 7px;
    padding-right: 7px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    border-bottom-left-radius: 4px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(90, 111, 160, 0.34);
    border-right-color: rgba(90, 111, 160, 0.34);
    border-top-color: rgba(90, 111, 160, 0.34);
    border-bottom-color: rgba(90, 111, 160, 0.34);
    background-color: rgba(22, 34, 43, 0.22);
    color: var(--deucarian-muted);
    font-size: 10px;
}

.dpi-ecosystem-graph__filter-toggle {
    flex-direction: row;
    align-items: center;
    justify-content: center;
    padding-left: 6px;
    padding-right: 6px;
}

.dpi-ecosystem-graph__filter-toggle--active {
    border-left-color: rgba(59, 166, 154, 0.48);
    border-right-color: rgba(59, 166, 154, 0.48);
    border-top-color: rgba(59, 166, 154, 0.48);
    border-bottom-color: rgba(59, 166, 154, 0.48);
    background-color: rgba(27, 55, 58, 0.36);
    color: rgba(224, 242, 244, 0.92);
}

.dpi-ecosystem-graph__filter-toggle--inactive {
    border-left-color: rgba(74, 86, 105, 0.32);
    border-right-color: rgba(74, 86, 105, 0.32);
    border-top-color: rgba(74, 86, 105, 0.32);
    border-bottom-color: rgba(74, 86, 105, 0.32);
    background-color: rgba(18, 24, 33, 0.18);
}

.dpi-ecosystem-graph__filter-icon {
    width: 14px;
    min-width: 14px;
    height: 14px;
    margin-right: 5px;
    padding-left: 0;
    padding-right: 0;
    border-top-left-radius: 3px;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
    border-bottom-left-radius: 3px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    -unity-text-align: middle-center;
    -unity-font-style: bold;
    font-size: 9px;
}

.dpi-ecosystem-graph__filter-icon--installed {
    color: rgba(215, 247, 238, 0.96);
    border-left-color: rgba(74, 202, 182, 0.64);
    border-right-color: rgba(74, 202, 182, 0.64);
    border-top-color: rgba(74, 202, 182, 0.64);
    border-bottom-color: rgba(74, 202, 182, 0.64);
    background-color: rgba(35, 116, 105, 0.18);
}

.dpi-ecosystem-graph__filter-icon--not-installed {
    color: rgba(166, 181, 194, 0.90);
    border-left-color: rgba(126, 145, 163, 0.54);
    border-right-color: rgba(126, 145, 163, 0.54);
    border-top-color: rgba(126, 145, 163, 0.54);
    border-bottom-color: rgba(126, 145, 163, 0.54);
    background-color: rgba(14, 20, 29, 0.08);
}

.dpi-ecosystem-graph__filter-label {
    color: rgba(224, 236, 240, 0.88);
    font-size: 10px;
}

.dpi-ecosystem-graph__filter-count {
    min-width: 17px;
    height: 14px;
    margin-left: 5px;
    padding-left: 4px;
    padding-right: 4px;
    border-top-left-radius: 3px;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
    border-bottom-left-radius: 3px;
    -unity-text-align: middle-center;
    color: rgba(170, 190, 202, 0.92);
    background-color: rgba(9, 14, 22, 0.18);
    font-size: 9px;
}

.dpi-ecosystem-graph__filter-clear {
    min-width: 52px;
    color: var(--deucarian-text);
}

.dpi-ecosystem-graph__visible-count {
    min-width: 58px;
    margin-left: 8px;
    color: var(--deucarian-muted);
    font-size: 10px;
}

.dpi-ecosystem-graph__hidden-related {
    margin-left: 8px;
    padding-left: 8px;
    padding-right: 8px;
    height: 18px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    border-bottom-left-radius: 4px;
    -unity-text-align: middle-center;
    color: rgba(255, 224, 176, 0.88);
    background-color: rgba(108, 72, 28, 0.42);
    font-size: 10px;
}

.dpi-ecosystem-graph__legend {
    flex-grow: 0;
    flex-shrink: 0;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    padding-left: 10px;
    padding-right: 8px;
    padding-bottom: 5px;
}

.dpi-ecosystem-graph__toolbar {
    flex-direction: row;
    align-items: center;
    justify-content: flex-end;
    min-width: 190px;
}

.dpi-ecosystem-graph__toolbar-button {
    height: 22px;
    min-width: 52px;
    margin-left: 5px;
    padding-left: 8px;
    padding-right: 8px;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
    border-bottom-right-radius: 5px;
    border-bottom-left-radius: 5px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(72, 150, 188, 0.38);
    border-right-color: rgba(72, 150, 188, 0.38);
    border-top-color: rgba(72, 150, 188, 0.38);
    border-bottom-color: rgba(72, 150, 188, 0.38);
    background-color: rgba(27, 48, 58, 0.68);
    color: var(--deucarian-text);
    font-size: 10px;
}

.dpi-ecosystem-graph__toolbar-button:hover {
    border-left-color: rgba(59, 209, 191, 0.56);
    border-right-color: rgba(59, 209, 191, 0.56);
    border-top-color: rgba(59, 209, 191, 0.56);
    border-bottom-color: rgba(59, 209, 191, 0.56);
    background-color: rgba(33, 66, 70, 0.74);
}

.dpi-graph-legend__item {
    flex-direction: row;
    align-items: center;
    margin-right: 14px;
    margin-top: 3px;
    margin-bottom: 3px;
}

.dpi-graph-legend__line {
    min-width: 44px;
    height: 16px;
    margin-right: 5px;
    -unity-text-align: middle-center;
    font-size: 8px;
    color: rgba(211, 230, 238, 0.72);
    border-bottom-width: 2px;
    border-bottom-color: rgba(90, 111, 160, 0.44);
}

.dpi-graph-legend__line--solid {
    border-bottom-color: rgba(116, 144, 196, 0.62);
}

.dpi-graph-legend__line--integration {
    border-bottom-color: rgba(59, 209, 191, 0.76);
}

.dpi-graph-legend__line--optional {
    border-bottom-color: rgba(116, 144, 164, 0.48);
}

.dpi-graph-legend__line--suite {
    border-bottom-color: rgba(59, 166, 154, 0.46);
}

.dpi-graph-legend__line--root {
    border-bottom-color: rgba(59, 209, 191, 0.70);
}

.dpi-graph-legend__line--group {
    border-bottom-color: rgba(126, 172, 202, 0.56);
}

.dpi-graph-legend__line--package {
    border-bottom-color: rgba(95, 119, 156, 0.52);
}

.dpi-graph-legend__line--membership {
    border-bottom-color: rgba(120, 170, 182, 0.34);
}

.dpi-graph-legend__line--installed {
    color: rgba(124, 214, 197, 0.94);
    border-bottom-color: rgba(59, 166, 154, 0.44);
}

.dpi-graph-legend__line--available {
    color: rgba(166, 181, 194, 0.92);
    border-bottom-color: rgba(116, 130, 150, 0.38);
}

.dpi-graph-legend__line--warning {
    color: rgba(255, 226, 184, 0.96);
    border-bottom-color: rgba(217, 157, 72, 0.86);
}

.dpi-graph-legend__label {
    color: var(--deucarian-muted);
    font-size: 10px;
}

.dpi-ecosystem-graph__viewport {
    flex-grow: 1;
    flex-shrink: 1;
    min-height: 0;
    position: relative;
    overflow: hidden;
    background-color: rgba(8, 14, 22, 0.18);
}

.dpi-ecosystem-graph__empty-state {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 300px;
    min-height: 88px;
    margin-left: -150px;
    margin-top: -44px;
    align-items: center;
    justify-content: center;
    padding-left: 16px;
    padding-right: 16px;
    padding-top: 14px;
    padding-bottom: 14px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
    border-bottom-left-radius: 8px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(90, 111, 160, 0.36);
    border-right-color: rgba(90, 111, 160, 0.36);
    border-top-color: rgba(90, 111, 160, 0.36);
    border-bottom-color: rgba(90, 111, 160, 0.36);
    background-color: rgba(12, 21, 30, 0.88);
}

.dpi-ecosystem-graph__empty-title {
    color: var(--deucarian-text);
    font-size: 12px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
}

.dpi-ecosystem-graph__empty-action {
    height: 24px;
    min-width: 108px;
    margin-top: 10px;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
    border-bottom-right-radius: 5px;
    border-bottom-left-radius: 5px;
    background-color: rgba(27, 48, 58, 0.76);
    color: var(--deucarian-text);
}

.dpi-ecosystem-graph__content {
    position: absolute;
    transform-origin: 0 0;
}

.dpi-ecosystem-graph__canvas {
    position: relative;
    background-color: rgba(8, 14, 22, 0);
}

.dpi-ecosystem-graph__guide-layer,
.dpi-ecosystem-graph__membership-layer,
.dpi-ecosystem-graph__edge-layer,
.dpi-ecosystem-graph__node-layer {
    position: absolute;
    left: 0;
    top: 0;
}

.dpi-graph-ring-guide {
    position: absolute;
    border-top-left-radius: 999px;
    border-top-right-radius: 999px;
    border-bottom-right-radius: 999px;
    border-bottom-left-radius: 999px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(90, 111, 160, 0.11);
    border-right-color: rgba(90, 111, 160, 0.11);
    border-top-color: rgba(90, 111, 160, 0.11);
    border-bottom-color: rgba(90, 111, 160, 0.11);
}

.dpi-graph-ring-guide--infrastructure {
    border-left-color: rgba(100, 137, 205, 0.17);
    border-right-color: rgba(100, 137, 205, 0.17);
    border-top-color: rgba(100, 137, 205, 0.17);
    border-bottom-color: rgba(100, 137, 205, 0.17);
}

.dpi-graph-ring-guide--runtime {
    border-left-color: rgba(64, 157, 187, 0.13);
    border-right-color: rgba(64, 157, 187, 0.13);
    border-top-color: rgba(64, 157, 187, 0.13);
    border-bottom-color: rgba(64, 157, 187, 0.13);
}

.dpi-graph-ring-guide--integration {
    border-left-color: rgba(59, 166, 154, 0.14);
    border-right-color: rgba(59, 166, 154, 0.14);
    border-top-color: rgba(59, 166, 154, 0.14);
    border-bottom-color: rgba(59, 166, 154, 0.14);
}

.dpi-graph-ring-guide--suite {
    border-left-color: rgba(118, 103, 184, 0.13);
    border-right-color: rgba(118, 103, 184, 0.13);
    border-top-color: rgba(118, 103, 184, 0.13);
    border-bottom-color: rgba(118, 103, 184, 0.13);
}

.dpi-graph-ring-guide__label {
    margin-left: 18px;
    margin-top: 10px;
    color: rgba(154, 194, 202, 0.42);
    font-size: 11px;
    -unity-font-style: bold;
}

.dpi-graph-sector-label {
    position: absolute;
    color: rgba(184, 218, 226, 0.72);
    font-size: 12px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    background-color: rgba(8, 15, 24, 0.36);
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    border-bottom-left-radius: 4px;
}

.dpi-ecosystem-graph__body {
    flex-grow: 1;
    flex-shrink: 1;
    flex-direction: row;
    align-items: stretch;
    min-height: 0;
}

.dpi-category-rail {
    width: 166px;
    min-width: 166px;
    max-width: 166px;
    flex-grow: 0;
    flex-shrink: 0;
    padding-left: 8px;
    padding-right: 8px;
    padding-top: 9px;
    padding-bottom: 9px;
    border-right-width: 1px;
    border-right-color: rgba(90, 111, 160, 0.22);
    background-color: rgba(12, 20, 28, 0.46);
}

.dpi-ecosystem-graph--compact .dpi-category-rail {
    width: 142px;
    min-width: 142px;
    max-width: 142px;
    padding-left: 6px;
    padding-right: 6px;
}

.dpi-ecosystem-graph--narrow .dpi-category-rail {
    width: 72px;
    min-width: 72px;
    max-width: 72px;
    padding-left: 5px;
    padding-right: 5px;
    padding-top: 7px;
    padding-bottom: 7px;
}

.dpi-category-rail--hidden {
    display: none;
}

.dpi-category-rail--locked {
    opacity: 0.68;
}

.dpi-category-rail__item {
    min-height: 46px;
    margin-bottom: 7px;
    padding-left: 6px;
    padding-right: 7px;
    padding-top: 6px;
    padding-bottom: 6px;
    flex-direction: row;
    align-items: center;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
    border-bottom-right-radius: 5px;
    border-bottom-left-radius: 5px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(90, 111, 160, 0.20);
    border-right-color: rgba(90, 111, 160, 0.16);
    border-top-color: rgba(90, 111, 160, 0.16);
    border-bottom-color: rgba(90, 111, 160, 0.16);
    background-color: rgba(17, 28, 38, 0.28);
}

.dpi-ecosystem-graph--narrow .dpi-category-rail__item {
    min-height: 48px;
    padding-left: 4px;
    padding-right: 4px;
    justify-content: center;
}

.dpi-category-rail__item:hover {
    border-left-color: rgba(59, 166, 154, 0.44);
    border-right-color: rgba(59, 166, 154, 0.34);
    border-top-color: rgba(59, 166, 154, 0.34);
    border-bottom-color: rgba(59, 166, 154, 0.34);
    background-color: rgba(23, 41, 49, 0.44);
}

.dpi-category-rail__item--active {
    border-left-color: rgba(59, 209, 191, 0.70);
    border-right-color: rgba(59, 209, 191, 0.48);
    border-top-color: rgba(59, 209, 191, 0.48);
    border-bottom-color: rgba(59, 209, 191, 0.48);
    background-color: rgba(27, 55, 58, 0.54);
}

.dpi-category-rail__item--hover-context {
    border-left-color: rgba(59, 209, 191, 0.62);
    border-right-color: rgba(59, 209, 191, 0.42);
    border-top-color: rgba(59, 209, 191, 0.42);
    border-bottom-color: rgba(59, 209, 191, 0.42);
}

.dpi-category-rail__symbol {
    min-width: 30px;
    min-height: 30px;
    max-width: 30px;
    max-height: 30px;
    margin-right: 8px;
    align-items: center;
    justify-content: center;
    border-top-left-radius: 999px;
    border-top-right-radius: 999px;
    border-bottom-right-radius: 999px;
