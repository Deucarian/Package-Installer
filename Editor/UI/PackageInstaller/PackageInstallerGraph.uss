    border-left-color: rgba(220, 178, 75, 0.72);
    border-right-color: rgba(220, 178, 75, 0.72);
    border-top-color: rgba(220, 178, 75, 0.72);
    border-bottom-color: rgba(220, 178, 75, 0.72);
    background-color: rgba(129, 96, 35, 0.10);
}

.dpi-graph-node__status-icon--warning {
    color: rgba(255, 226, 194, 0.98);
    border-left-color: rgba(223, 135, 68, 0.68);
    border-right-color: rgba(223, 135, 68, 0.68);
    border-top-color: rgba(223, 135, 68, 0.68);
    border-bottom-color: rgba(223, 135, 68, 0.68);
    background-color: rgba(137, 75, 35, 0.10);
}

.dpi-graph-node__status-icon--missing {
    color: rgba(255, 224, 216, 0.98);
    border-left-color: rgba(225, 105, 91, 0.70);
    border-right-color: rgba(225, 105, 91, 0.70);
    border-top-color: rgba(225, 105, 91, 0.70);
    border-bottom-color: rgba(225, 105, 91, 0.70);
    background-color: rgba(137, 54, 45, 0.10);
}

.dpi-graph-node__title-block {
    flex-grow: 1;
    min-width: 0;
}

.dpi-graph-node__title {
    color: var(--deucarian-text);
    -unity-font-style: bold;
    font-size: 12px;
    white-space: normal;
    max-height: 30px;
}

.dpi-graph-node__package-id {
    color: var(--deucarian-muted);
    font-size: 9px;
    white-space: normal;
    max-height: 18px;
}

.dpi-graph-node__category-path {
    margin-top: 2px;
    color: rgba(139, 184, 196, 0.76);
    font-size: 9px;
    white-space: normal;
    max-height: 18px;
}

.dpi-ecosystem-graph__content--low-zoom .dpi-graph-node__package-id,
.dpi-ecosystem-graph__content--low-zoom .dpi-graph-node__category-path,
.dpi-ecosystem-graph__content--low-zoom .dpi-graph-node__badges,
.dpi-ecosystem-graph__content--low-zoom .dpi-graph-node__footer,
.dpi-ecosystem-graph__content--low-zoom .dpi-graph-node--stack .dpi-graph-node__badges,
.dpi-ecosystem-graph__content--low-zoom .dpi-graph-node--stack .dpi-graph-node__footer {
    display: none;
}

.dpi-ecosystem-graph__content--low-zoom .dpi-graph-node {
    padding-left: 10px;
    padding-right: 8px;
    padding-top: 8px;
}

.dpi-ecosystem-graph__content--low-zoom .dpi-graph-node__header {
    min-height: 32px;
    max-height: 36px;
    align-items: center;
}

.dpi-ecosystem-graph__content--low-zoom .dpi-graph-node__icon {
    width: 24px;
    height: 24px;
    min-width: 24px;
}

.dpi-ecosystem-graph__content--low-zoom .dpi-graph-node__title {
    font-size: 10px;
    max-height: 24px;
}

.dpi-ecosystem-graph__content--low-zoom .dpi-graph-node__status-icon {
    width: 12px;
    min-width: 12px;
    height: 12px;
    font-size: 7px;
    margin-right: 5px;
}

.dpi-ecosystem-graph__content--low-zoom .dpi-graph-group__stats {
    display: none;
}

.dpi-ecosystem-graph__content--low-zoom .dpi-graph-group__title {
    font-size: 11px;
}

.dpi-ecosystem-graph__content--low-zoom .dpi-graph-group__subtitle {
    font-size: 8px;
}

.dpi-graph-node__badges {
    flex-direction: row;
    margin-top: 7px;
    margin-bottom: 6px;
    min-height: 18px;
}

.dpi-graph-node__badge {
    height: 18px;
    margin-right: 4px;
    font-size: 9px;
    max-width: 96px;
    padding-left: 0;
    padding-right: 8px;
    color: rgba(190, 207, 214, 0.86);
    background-color: rgba(0, 0, 0, 0);
}

.dpi-graph-node__badge--type {
    color: rgba(139, 174, 194, 0.82);
}

.dpi-graph-node__badge--installed {
    color: rgba(124, 214, 197, 0.90);
}

.dpi-graph-node__badge--available {
    color: rgba(166, 181, 194, 0.88);
}

.dpi-graph-node__badge--update {
    color: rgba(255, 236, 184, 0.96);
}

.dpi-graph-node__badge--checking {
    color: rgba(151, 206, 226, 0.88);
}

.dpi-graph-node__badge--warning {
    color: rgba(255, 215, 172, 0.92);
}

.dpi-graph-node__badge--missing {
    color: rgba(255, 198, 176, 0.92);
}

.dpi-graph-node__footer {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    min-height: 24px;
}

.dpi-graph-node__channel {
    color: rgba(154, 194, 202, 0.76);
    font-size: 9px;
}

.dpi-graph-node__action {
    min-width: 76px;
    height: 22px;
    padding-left: 8px;
    padding-right: 8px;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
    border-bottom-right-radius: 5px;
    border-bottom-left-radius: 5px;
    background-color: rgba(35, 82, 87, 0.68);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(59, 166, 154, 0.48);
    border-right-color: rgba(59, 166, 154, 0.48);
    border-top-color: rgba(59, 166, 154, 0.48);
    border-bottom-color: rgba(59, 166, 154, 0.48);
    color: var(--deucarian-text);
    font-size: 10px;
}

.dpi-graph-node__action:hover {
    background-color: rgba(42, 108, 112, 0.76);
    border-left-color: rgba(59, 166, 154, 0.70);
    border-right-color: rgba(59, 166, 154, 0.70);
    border-top-color: rgba(59, 166, 154, 0.70);
    border-bottom-color: rgba(59, 166, 154, 0.70);
}

.dpi-graph-node--status-update .dpi-graph-node__action {
    background-color: rgba(112, 84, 31, 0.82);
    border-left-color: rgba(224, 178, 72, 0.60);
    border-right-color: rgba(224, 178, 72, 0.60);
    border-top-color: rgba(224, 178, 72, 0.60);
    border-bottom-color: rgba(224, 178, 72, 0.60);
    color: rgba(255, 241, 206, 0.98);
}

.dpi-graph-node--status-update .dpi-graph-node__action:hover {
    background-color: rgba(132, 100, 38, 0.90);
    border-left-color: rgba(240, 194, 88, 0.82);
    border-right-color: rgba(240, 194, 88, 0.82);
    border-top-color: rgba(240, 194, 88, 0.82);
    border-bottom-color: rgba(240, 194, 88, 0.82);
}
