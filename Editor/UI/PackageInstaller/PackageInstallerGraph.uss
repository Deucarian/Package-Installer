.dpi-global-channel-popup {
    position: absolute;
    flex-direction: column;
    padding-left: 10px;
    padding-right: 10px;
    padding-top: 8px;
    padding-bottom: 8px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
    border-bottom-left-radius: 8px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(59, 166, 154, 0.42);
    border-right-color: rgba(59, 166, 154, 0.34);
    border-top-color: rgba(126, 172, 202, 0.34);
    border-bottom-color: rgba(59, 166, 154, 0.28);
    background-color: rgba(12, 22, 31, 0.96);
}

.dpi-global-channel-popup__title {
    color: var(--deucarian-text);
    -unity-font-style: bold;
    font-size: 12px;
}

.dpi-global-channel-popup__message {
    margin-top: 5px;
    color: var(--deucarian-muted);
    font-size: 11px;
    white-space: normal;
}

.dpi-global-channel-popup__dropdown {
    margin-top: 9px;
}

.dpi-global-channel-popup__actions {
    flex-direction: row;
    justify-content: flex-end;
    margin-top: 10px;
}

.dpi-global-channel-popup__apply {
    height: 28px;
    min-height: 28px;
    max-height: 28px;
    min-width: 106px;
    padding-left: 8px;
    padding-right: 8px;
    padding-top: 0;
    padding-bottom: 0;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
    border-bottom-right-radius: 5px;
    border-bottom-left-radius: 5px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(59, 166, 154, 0.48);
    border-right-color: rgba(59, 166, 154, 0.48);
    border-top-color: rgba(59, 166, 154, 0.48);
    border-bottom-color: rgba(59, 166, 154, 0.48);
    background-color: rgba(35, 82, 87, 0.68);
    color: var(--deucarian-text);
    font-size: 10px;
}

.dpi-global-channel-popup__apply--primary {
    margin-left: 8px;
}

.dpi-global-channel-popup__apply:hover {
    border-left-color: rgba(59, 209, 191, 0.70);
    border-right-color: rgba(59, 209, 191, 0.70);
    border-top-color: rgba(59, 209, 191, 0.70);
    border-bottom-color: rgba(59, 209, 191, 0.70);
    background-color: rgba(42, 108, 112, 0.76);
}

.dpi-mode-container {
    flex-grow: 1;
    flex-shrink: 1;
    min-height: 0;
}

.dpi-mode-container--hidden {
    display: none;
}

.dpi-graph-mode {
    flex-grow: 1;
    flex-shrink: 1;
    flex-direction: column;
    min-height: 0;
}

.dpi-graph-content-row {
    flex-grow: 1;
    flex-shrink: 1;
    flex-basis: 0;
    flex-direction: row;
    align-items: stretch;
    min-height: 0;
    margin-bottom: 8px;
}

.dpi-graph-details {
    width: 410px;
    min-width: 360px;
    max-width: 440px;
    flex-grow: 0;
    flex-shrink: 0;
    align-self: stretch;
    min-height: 0;
    margin-left: 8px;
    overflow: hidden;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(90, 111, 160, 0.30);
    border-right-color: rgba(90, 111, 160, 0.24);
    border-top-color: rgba(126, 172, 202, 0.28);
    border-bottom-color: rgba(59, 166, 154, 0.18);
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
    border-bottom-left-radius: 8px;
    background-color: rgba(12, 22, 31, 0.60);
}

.deucarian-responsive--compact .dpi-graph-details {
    width: 350px;
    min-width: 310px;
    max-width: 370px;
}

.deucarian-responsive--narrow .dpi-graph-content-row {
    flex-direction: column;
    margin-bottom: 6px;
}

.deucarian-responsive--narrow .dpi-graph-details {
    width: auto;
    min-width: 0;
    max-width: none;
    height: 190px;
    min-height: 150px;
    max-height: 220px;
    margin-left: 0;
    margin-top: 8px;
    align-self: stretch;
    flex-grow: 0;
    flex-shrink: 0;
}

.dpi-ecosystem-graph {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 420px;
    min-height: 0;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
    border-bottom-left-radius: 8px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(90, 111, 160, 0.34);
    border-right-color: rgba(90, 111, 160, 0.34);
    border-top-color: rgba(90, 111, 160, 0.34);
    border-bottom-color: rgba(90, 111, 160, 0.34);
    background-color: rgba(11, 18, 25, 0.62);
}

.deucarian-responsive--narrow .dpi-ecosystem-graph {
    min-width: 0;
    min-height: 300px;
}

.dpi-ecosystem-graph__header {
    flex-shrink: 0;
    flex-direction: column;
    align-items: stretch;
    padding-left: 10px;
    padding-right: 10px;
    padding-top: 8px;
    padding-bottom: 8px;
    border-bottom-width: 1px;
    border-bottom-color: rgba(59, 166, 154, 0.16);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-left-color: rgba(90, 111, 160, 0.24);
    border-right-color: rgba(90, 111, 160, 0.18);
    border-top-color: rgba(128, 160, 192, 0.22);
    border-top-left-radius: 7px;
    border-top-right-radius: 7px;
    background-color: rgba(11, 21, 30, 0.58);
}

.dpi-ecosystem-graph__filter-row {
    min-height: 36px;
    flex-direction: row;
    align-items: center;
    padding-left: 0;
    padding-right: 0;
    padding-top: 0;
    padding-bottom: 0;
}

.dpi-ecosystem-graph--compact .dpi-ecosystem-graph__filter-row,
.dpi-ecosystem-graph--narrow .dpi-ecosystem-graph__filter-row {
    flex-wrap: wrap;
    align-content: flex-start;
}

.dpi-ecosystem-graph--compact .dpi-ecosystem-graph__search {
    flex-basis: 220px;
    max-width: none;
}

.dpi-ecosystem-graph--narrow .dpi-ecosystem-graph__search {
    flex-basis: 100%;
    width: 100%;
    max-width: none;
    margin-right: 0;
    margin-bottom: 5px;
}

.dpi-ecosystem-graph--narrow .dpi-ecosystem-graph__filter-toggle {
    min-width: 88px;
}

.dpi-ecosystem-graph--compact .dpi-ecosystem-graph__toolbar,
.dpi-ecosystem-graph--narrow .dpi-ecosystem-graph__toolbar {
    flex-grow: 1;
    min-width: 174px;
    margin-top: 4px;
}

.dpi-ecosystem-graph--narrow .deucarian-toolbar-spacer {
    display: none;
}

.dpi-ecosystem-graph__breadcrumbs {
    min-height: 24px;
    flex-direction: row;
    align-items: center;
    padding-left: 0;
    padding-right: 0;
    padding-top: 0;
    padding-bottom: 0;
    overflow: hidden;
}

.dpi-ecosystem-graph--compact .dpi-ecosystem-graph__breadcrumb,
.dpi-ecosystem-graph--compact .dpi-ecosystem-graph__breadcrumb-current,
.dpi-ecosystem-graph--narrow .dpi-ecosystem-graph__breadcrumb,
.dpi-ecosystem-graph--narrow .dpi-ecosystem-graph__breadcrumb-current {
    flex-shrink: 1;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    -unity-text-overflow-position: end;
}

.dpi-ecosystem-graph__breadcrumbs--root {
    opacity: 0.78;
}

.dpi-ecosystem-graph__breadcrumb {
    height: 20px;
    min-width: 0;
    padding-left: 8px;
    padding-right: 8px;
    border-top-left-radius: 3px;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
    border-bottom-left-radius: 3px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(90, 111, 160, 0.26);
    border-right-color: rgba(90, 111, 160, 0.26);
    border-top-color: rgba(90, 111, 160, 0.26);
    border-bottom-color: rgba(90, 111, 160, 0.26);
    background-color: rgba(14, 27, 38, 0.58);
    color: rgba(205, 224, 230, 0.86);
    font-size: 10px;
}

.dpi-ecosystem-graph__breadcrumb:hover {
    border-left-color: rgba(59, 166, 154, 0.48);
    border-right-color: rgba(59, 166, 154, 0.48);
    border-top-color: rgba(59, 166, 154, 0.48);
    border-bottom-color: rgba(59, 166, 154, 0.48);
    background-color: rgba(27, 52, 57, 0.68);
}

.dpi-ecosystem-graph__breadcrumb:focus {
    border-left-color: rgba(111, 235, 220, 0.88);
    border-right-color: rgba(111, 235, 220, 0.88);
    border-top-color: rgba(111, 235, 220, 0.88);
    border-bottom-color: rgba(111, 235, 220, 0.88);
    background-color: rgba(25, 58, 64, 0.82);
}

.dpi-ecosystem-graph__breadcrumb:active {
    border-left-color: rgba(59, 209, 191, 0.72);
    border-right-color: rgba(59, 209, 191, 0.72);
    border-top-color: rgba(59, 209, 191, 0.72);
    border-bottom-color: rgba(59, 209, 191, 0.72);
    background-color: rgba(18, 43, 50, 0.82);
    color: rgba(236, 250, 251, 0.98);
}

.dpi-ecosystem-graph__breadcrumb-current {
    height: 20px;
    padding-left: 8px;
    padding-right: 8px;
    color: rgba(230, 242, 245, 0.92);
    font-size: 10px;
    -unity-font-style: bold;
}

.dpi-ecosystem-graph__breadcrumb-separator {
    width: 12px;
    color: rgba(112, 143, 156, 0.70);
    -unity-text-align: middle-center;
    font-size: 10px;
}

.dpi-ecosystem-graph__search {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 130px;
    max-width: 360px;
    height: 24px;
    margin-right: 6px;
}

.dpi-ecosystem-graph__filter-toggle,
.dpi-ecosystem-graph__filter-clear {
    height: 22px;
    min-width: 96px;
    margin-left: 4px;
    padding-left: 7px;
    padding-right: 7px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    border-bottom-left-radius: 4px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(90, 111, 160, 0.34);
    border-right-color: rgba(90, 111, 160, 0.34);
    border-top-color: rgba(90, 111, 160, 0.34);
    border-bottom-color: rgba(90, 111, 160, 0.34);
    background-color: rgba(22, 34, 43, 0.22);
    color: var(--deucarian-muted);
    font-size: 10px;
}

.dpi-ecosystem-graph__filter-toggle {
    flex-direction: row;
    align-items: center;
    justify-content: center;
    padding-left: 6px;
    padding-right: 6px;
}

.dpi-ecosystem-graph__filter-toggle--active {
    border-left-color: rgba(59, 166, 154, 0.48);
    border-right-color: rgba(59, 166, 154, 0.48);
    border-top-color: rgba(59, 166, 154, 0.48);
    border-bottom-color: rgba(59, 166, 154, 0.48);
    background-color: rgba(27, 55, 58, 0.36);
    color: rgba(224, 242, 244, 0.92);
}

.dpi-ecosystem-graph__filter-toggle--inactive {
    border-left-color: rgba(74, 86, 105, 0.32);
    border-right-color: rgba(74, 86, 105, 0.32);
    border-top-color: rgba(74, 86, 105, 0.32);
    border-bottom-color: rgba(74, 86, 105, 0.32);
    background-color: rgba(18, 24, 33, 0.18);
}

.dpi-ecosystem-graph__filter-toggle:hover,
.dpi-ecosystem-graph__filter-clear:hover {
    border-left-color: rgba(59, 209, 191, 0.56);
    border-right-color: rgba(59, 209, 191, 0.56);
    border-top-color: rgba(59, 209, 191, 0.56);
    border-bottom-color: rgba(59, 209, 191, 0.56);
    background-color: rgba(29, 57, 63, 0.58);
    color: rgba(230, 244, 246, 0.96);
}

.dpi-ecosystem-graph__filter-toggle:active,
.dpi-ecosystem-graph__filter-clear:active {
    border-left-color: rgba(59, 209, 191, 0.78);
    border-right-color: rgba(59, 209, 191, 0.78);
    border-top-color: rgba(59, 209, 191, 0.78);
    border-bottom-color: rgba(59, 209, 191, 0.78);
    background-color: rgba(18, 43, 50, 0.78);
    color: rgba(238, 250, 251, 1.00);
}

.dpi-ecosystem-graph__filter-toggle:hover .dpi-ecosystem-graph__filter-label,
.dpi-ecosystem-graph__filter-toggle:active .dpi-ecosystem-graph__filter-label {
    color: rgba(238, 250, 251, 0.98);
}

.dpi-ecosystem-graph__filter-toggle:hover .dpi-ecosystem-graph__filter-count,
.dpi-ecosystem-graph__filter-toggle:active .dpi-ecosystem-graph__filter-count {
    color: rgba(221, 241, 245, 0.96);
    background-color: rgba(8, 17, 24, 0.34);
}

.dpi-ecosystem-graph__filter-icon {
    width: 14px;
    min-width: 14px;
    height: 14px;
    margin-right: 5px;
    padding-left: 0;
    padding-right: 0;
    border-top-left-radius: 3px;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
    border-bottom-left-radius: 3px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    -unity-text-align: middle-center;
    -unity-font-style: bold;
    font-size: 9px;
}

.dpi-ecosystem-graph__filter-icon--installed {
    color: rgba(215, 247, 238, 0.96);
    border-left-color: rgba(74, 202, 182, 0.64);
    border-right-color: rgba(74, 202, 182, 0.64);
    border-top-color: rgba(74, 202, 182, 0.64);
    border-bottom-color: rgba(74, 202, 182, 0.64);
    background-color: rgba(35, 116, 105, 0.18);
}

.dpi-ecosystem-graph__filter-icon--not-installed {
    color: rgba(213, 207, 247, 0.92);
    border-left-color: rgba(130, 119, 204, 0.58);
    border-right-color: rgba(130, 119, 204, 0.58);
    border-top-color: rgba(130, 119, 204, 0.58);
    border-bottom-color: rgba(130, 119, 204, 0.58);
    background-color: rgba(76, 68, 132, 0.12);
}

.dpi-ecosystem-graph__filter-label {
    color: rgba(224, 236, 240, 0.88);
    font-size: 10px;
}

.dpi-ecosystem-graph__filter-count {
    min-width: 17px;
    height: 14px;
    margin-left: 5px;
    padding-left: 4px;
    padding-right: 4px;
    border-top-left-radius: 3px;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
    border-bottom-left-radius: 3px;
    -unity-text-align: middle-center;
    color: rgba(170, 190, 202, 0.92);
    background-color: rgba(9, 14, 22, 0.18);
    font-size: 9px;
}

.dpi-ecosystem-graph__filter-clear {
    min-width: 52px;
    color: var(--deucarian-text);
}

.dpi-ecosystem-graph__visible-count {
    min-width: 58px;
    margin-left: 8px;
    color: var(--deucarian-muted);
    font-size: 10px;
}

.dpi-ecosystem-graph__hidden-related {
    margin-left: 8px;
    padding-left: 8px;
    padding-right: 8px;
    height: 18px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    border-bottom-left-radius: 4px;
    -unity-text-align: middle-center;
    color: rgba(255, 224, 176, 0.88);
    background-color: rgba(108, 72, 28, 0.42);
    font-size: 10px;
}

.dpi-ecosystem-graph__legend {
    flex-grow: 0;
    flex-shrink: 0;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    padding-left: 10px;
    padding-right: 8px;
    padding-bottom: 5px;
    background-color: rgba(7, 15, 24, 0.12);
}

.dpi-ecosystem-graph__toolbar {
    flex-direction: row;
    align-items: center;
    justify-content: flex-end;
    min-width: 190px;
}

.dpi-ecosystem-graph__toolbar-button {
    height: 22px;
    min-width: 52px;
    margin-left: 5px;
    padding-left: 8px;
    padding-right: 8px;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
    border-bottom-right-radius: 5px;
    border-bottom-left-radius: 5px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(72, 150, 188, 0.38);
    border-right-color: rgba(72, 150, 188, 0.38);
    border-top-color: rgba(72, 150, 188, 0.38);
    border-bottom-color: rgba(72, 150, 188, 0.38);
    background-color: rgba(18, 36, 48, 0.58);
    color: var(--deucarian-text);
    font-size: 10px;
}

.dpi-ecosystem-graph__toolbar-button:hover {
    border-left-color: rgba(59, 209, 191, 0.56);
    border-right-color: rgba(59, 209, 191, 0.56);
    border-top-color: rgba(59, 209, 191, 0.56);
    border-bottom-color: rgba(59, 209, 191, 0.56);
    background-color: rgba(33, 66, 70, 0.74);
}

.dpi-ecosystem-graph__toolbar-button:active {
    border-left-color: rgba(59, 209, 191, 0.78);
    border-right-color: rgba(59, 209, 191, 0.78);
    border-top-color: rgba(59, 209, 191, 0.78);
    border-bottom-color: rgba(59, 209, 191, 0.78);
    background-color: rgba(20, 48, 56, 0.82);
}

.dpi-graph-legend__item {
    flex-direction: row;
    align-items: center;
    margin-right: 14px;
    margin-top: 3px;
    margin-bottom: 3px;
}

.dpi-graph-legend__line {
    min-width: 44px;
    height: 16px;
    margin-right: 5px;
    -unity-text-align: middle-center;
    font-size: 8px;
    color: rgba(211, 230, 238, 0.72);
    border-bottom-width: 2px;
    border-bottom-color: rgba(90, 111, 160, 0.44);
}

.dpi-graph-legend__line--solid {
    border-bottom-color: rgba(116, 144, 196, 0.62);
}

.dpi-graph-legend__line--integration {
    border-bottom-color: rgba(59, 209, 191, 0.76);
}

.dpi-graph-legend__line--optional {
    border-bottom-color: rgba(116, 144, 164, 0.48);
}

.dpi-graph-legend__line--suite {
    border-bottom-color: rgba(59, 166, 154, 0.46);
}

.dpi-graph-legend__line--root {
    border-bottom-color: rgba(59, 209, 191, 0.70);
}

.dpi-graph-legend__line--group {
    border-bottom-color: rgba(126, 172, 202, 0.56);
}

.dpi-graph-legend__line--package {
    border-bottom-color: rgba(95, 119, 156, 0.52);
}

.dpi-graph-legend__line--membership {
    border-bottom-color: rgba(120, 170, 182, 0.34);
}

.dpi-graph-legend__line--installed {
    color: rgba(124, 214, 197, 0.94);
    border-bottom-color: rgba(59, 166, 154, 0.44);
}

.dpi-graph-legend__line--available {
    color: rgba(213, 207, 247, 0.92);
    border-bottom-color: rgba(130, 119, 204, 0.54);
}

.dpi-graph-legend__line--warning {
    color: rgba(255, 226, 184, 0.96);
    border-bottom-color: rgba(217, 157, 72, 0.86);
}

.dpi-graph-legend__line--checking {
    color: rgba(174, 222, 238, 0.96);
    border-bottom-color: rgba(82, 171, 205, 0.76);
}

.dpi-graph-legend__label {
    color: var(--deucarian-muted);
    font-size: 10px;
}

.dpi-ecosystem-graph__viewport {
    flex-grow: 1;
    flex-shrink: 1;
    min-height: 0;
    position: relative;
    overflow: hidden;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(90, 111, 160, 0.22);
    border-right-color: rgba(90, 111, 160, 0.18);
    border-top-color: rgba(120, 154, 190, 0.22);
    border-bottom-color: rgba(59, 166, 154, 0.14);
    background-color: rgba(7, 13, 21, 0.23);
}

.dpi-graph-spotlight-layer {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    overflow: hidden;
}

.dpi-graph-spotlight {
    position: absolute;
    -unity-background-scale-mode: scale-and-crop;
}

.dpi-ecosystem-graph__empty-state {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 300px;
    min-height: 88px;
    margin-left: -150px;
    margin-top: -44px;
    align-items: center;
    justify-content: center;
    padding-left: 10px;
    padding-right: 10px;
    padding-top: 8px;
    padding-bottom: 8px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
    border-bottom-left-radius: 8px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(90, 111, 160, 0.36);
    border-right-color: rgba(90, 111, 160, 0.36);
    border-top-color: rgba(90, 111, 160, 0.36);
    border-bottom-color: rgba(90, 111, 160, 0.36);
    background-color: rgba(12, 21, 30, 0.88);
}

.dpi-ecosystem-graph__empty-title {
    color: var(--deucarian-text);
    font-size: 12px;
    -unity-font-style: bold;
